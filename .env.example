# Environment variables template
# Copy to .env and fill in your values

# OpenRouter API key (get one at https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-...

# OpenRouter base URL (default: https://openrouter.ai/api/v1)
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# LLM model identifier (any model available on OpenRouter)
# Examples: anthropic/claude-sonnet-4-20250514, openai/gpt-4o, google/gemini-2.0-flash-001
# LLM_MODEL=anthropic/claude-sonnet-4-20250514

# Max tokens for LLM responses
# LLM_MAX_TOKENS=4096

# Database URL (defaults to SQLite in data/gre_mock.db if not set)
# DATABASE_URL=sqlite:///data/gre_mock.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/gre_mock

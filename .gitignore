# .gitignore for GRE Mock Testing Platform

# Virtual environment
venv/
.venv/
env/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# Database WAL/journal sidecar files (the .db itself ships via Git LFS)
data/*.db-journal
data/*.db-shm
data/*.db-wal
# Per-user runtime DB — bootstrapped from the shipped data/gre_mock.db
# seed on first launch by config._bootstrap_user_db. Never tracked, so
# user state (sessions, responses, mastery, flags) doesn't churn the
# tracked seed file and block `git pull` for the next sync.
data/gre_user.db
data/gre_user.db-*
# Autosave / crash-recovery artifacts (per-run, never useful in version control)
data/autosave_journal.jsonl
data/autosave_journal.*.jsonl.bak
data/awa_draft_*.txt
data/gre_app.log
data/gre_app.log.*

# Source ebooks and intermediate extraction artifacts (large, binary, generated)
data/ebooks/
data/extracted/
data/images/
data/llm_config.json

# Local-only files (build infrastructure, private notes, etc.) marked
# by a leading underscore in the filename. Tracked locally only; never
# pushed. Excludes Python's reserved dunder files (__init__, __main__).
_*.py
!__init__.py
!__main__.py

# Coverage / profiling artifacts
*.profraw
*.profdata
.coverage

# Environment
.env
.env.local

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log
setup.log

# Blueprint PDF (large binary)
*.pdf
